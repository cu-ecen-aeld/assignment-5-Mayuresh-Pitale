#!/bin/sh
# /etc/init.d/S98lddmodules

case "$1" in
    start)
        echo "Loading LDD modules..."
        
        # 1. Load hello
        modprobe hello

        # 2. Load scull (modprobe works fine here, no builtin conflict)
        modprobe scull
        major=$(awk '$2=="scull" {print $1}' /proc/devices)
        if [ ! -z "$major" ]; then
            rm -f /dev/scull[0-3]
            mknod /dev/scull0 c $major 0
            mknod /dev/scull1 c $major 1
            mknod /dev/scull2 c $major 2
            mknod /dev/scull3 c $major 3
            chmod 666 /dev/scull[0-3]
        fi

        # 3. Load faulty (Must use insmod due to builtin md-faulty conflict)
        # Use a flexible ls wildcard to find the exact path
        FAULTY_MOD=$(ls /lib/modules/*/extra/faulty.ko /lib/modules/*/extra/*/faulty.ko 2>/dev/null | head -n 1)
        if [ -n "$FAULTY_MOD" ]; then
            insmod "$FAULTY_MOD"
            major=$(awk '$2=="faulty" {print $1}' /proc/devices)
            if [ ! -z "$major" ]; then
                rm -f /dev/faulty
                mknod /dev/faulty c $major 0
                chmod 666 /dev/faulty
            fi
        else
            echo "ERROR: faulty.ko not found in /lib/modules!"
        fi
        ;;
    stop)
        echo "Unloading LDD modules..."
        rmmod hello 2>/dev/null
        rmmod faulty 2>/dev/null
        rmmod scull 2>/dev/null
        rm -f /dev/faulty
        rm -f /dev/scull[0-3]
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
esac

exit 0
