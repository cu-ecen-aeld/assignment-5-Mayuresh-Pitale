#!/bin/sh
# /etc/init.d/S98lddmodules

case "$1" in
    start)
        echo "Loading LDD modules..."
        
        # 1. Load hello module via modprobe
        modprobe hello

        # 2. Load faulty module (using insmod bypasses the CONFIG_MD_FAULTY conflict)
        insmod /lib/modules/$(uname -r)/extra/faulty.ko
        major=$(awk '$2=="faulty" {print $1}' /proc/devices)
        if [ ! -z "$major" ]; then
            rm -f /dev/faulty
            mknod /dev/faulty c $major 0
            chmod 666 /dev/faulty
        fi
        
        # 3. Load scull module
        insmod /lib/modules/$(uname -r)/extra/scull.ko
        major=$(awk '$2=="scull" {print $1}' /proc/devices)
        if [ ! -z "$major" ]; then
            rm -f /dev/scull[0-3]
            mknod /dev/scull0 c $major 0
            mknod /dev/scull1 c $major 1
            mknod /dev/scull2 c $major 2
            mknod /dev/scull3 c $major 3
            chmod 666 /dev/scull[0-3]
        fi
        ;;
    stop)
        echo "Unloading LDD modules..."
        rmmod hello
        rmmod faulty
        rmmod scull
        rm -f /dev/faulty
        rm -f /dev/scull[0-3]
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
esac

exit 0
